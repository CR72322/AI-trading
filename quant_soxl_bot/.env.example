# ============================================================================
# Alpaca API Configuration
# ============================================================================
# 1. Sign up at https://alpaca.markets and get your API keys.
# 2. Copy this file:  cp .env.example .env
# 3. Fill in your real keys below.
# 4. NEVER commit .env to version control.
# ============================================================================

ALPACA_API_KEY="your-api-key-here"
ALPACA_SECRET_KEY="your-secret-key-here"

# Paper trading endpoint (default). Switch to live when ready:
#   https://api.alpaca.markets
ALPACA_BASE_URL="https://paper-api.alpaca.markets"
